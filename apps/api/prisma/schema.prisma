generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PaletteGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  brand       String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  colors      PaletteColor[]
}

model PaletteColor {
  id        String   @id @default(cuid())
  groupId   String
  code      String
  name      String
  hex       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     PaletteGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, code])
  @@index([groupId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions        AuthSession[]
  projects        Project[]
  customPaletteGroups CustomPaletteGroup[]
  settings        UserSetting?
  creatorProfile  CreatorProfile?
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  latestSnapshot String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  ProjectVersion[]

  @@index([userId, updatedAt])
}

model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  at        DateTime @default(now())
  reason    String
  note      String?
  snapshot  String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, at])
}

model CustomPaletteGroup {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  colors    CustomPaletteColor[]

  @@index([userId, updatedAt])
}

model CustomPaletteColor {
  id        String   @id @default(cuid())
  groupId   String
  code      String
  hex       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     CustomPaletteGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model UserSetting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  shortcutConfig        String?
  constructionTemplates String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  externalLinks   String?
  acceptingOrders Boolean  @default(true)
  styleTags       String?
  watermarkText   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designs         Design[]
}

model Design {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String?
  tags        String?
  licenseType    String   @default("personal")
  price          Int?
  estimatedTime  String?
  previewImage   String?
  status         String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, status])
  @@index([status, updatedAt])
}
